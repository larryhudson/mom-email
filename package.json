{
	"name": "mom-email",
	"version": "0.1.0",
	"description": "Email assistant powered by Claude, using Mailgun for email transport",
	"type": "module",
	"bin": {
		"mom": "dist/main.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"CHANGELOG.md"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"type-check": "tsgo -p tsconfig.build.json --noEmit",
		"build": "tsgo -p tsconfig.build.json && chmod +x dist/main.js",
		"dev": "IS_DRY_RUN=true tsx --watch src/main.ts ./data",
		"send-email": "tsx scripts/send-email.ts",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@anthropic-ai/sandbox-runtime": "^0.0.16",
		"@mariozechner/pi-agent-core": "^0.55.3",
		"@mariozechner/pi-ai": "^0.55.3",
		"@mariozechner/pi-coding-agent": "^0.55.3",
		"@sinclair/typebox": "^0.34.0",
		"chalk": "^5.6.2",
		"croner": "^9.1.0",
		"diff": "^8.0.2",
		"dotenv": "^17.3.1",
		"marked": "^17.0.3"
	},
	"devDependencies": {
		"@types/diff": "^7.0.2",
		"@types/node": "^24.3.0",
		"@typescript/native-preview": "^7.0.0-dev.20260228.1",
		"tsx": "^4.21.0",
		"typescript": "^5.7.3"
	},
	"keywords": [
		"email",
		"mailgun",
		"ai",
		"agent",
		"claude"
	],
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0"
	}
}
